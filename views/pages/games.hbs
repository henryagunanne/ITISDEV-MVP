<link rel="stylesheet" href="/src/css/admin-games.css">

<div class="col-md-10 main" id="gamesPage">

    <!-- Page Header -->
    <div class="dashboard-header">
        <h2><i class="fas fa-calendar-alt me-2"></i>Games</h2>
        <div class="controls">
            <input type="text" id="searchOpponent" placeholder="&#128269; Search opponent...">
            <select id="filterResult">
                <option value="">All Results</option>
                <option value="Win">Win</option>
                <option value="Loss">Loss</option>
            </select>
            <select id="filterStatus">
                <option value="">All Status</option>
                <option value="NOT_STARTED">Not Started</option>
                <option value="PLAYING">Playing</option>
                <option value="PAUSED">Paused</option>
                <option value="ENDED">Ended</option>
            </select>
            {{#if isAdminOrCoach}}
            <button class="add-game" id="openAddModal">
                <i class="fas fa-plus"></i> Add Game
            </button>
            {{/if}}
        </div>
    </div>

    <!-- Games Table -->
    <div class="table-container">
        <table id="gamesTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Opponent</th>
                    <th>Tournament</th>
                    <th>Venue</th>
                    <th>Score</th>
                    <th>Result</th>
                    <th>Status</th>
                    {{#if isAdminOrCoach}}<th>Actions</th>{{/if}}
                </tr>
            </thead>
            <tbody id="gamesTableBody">
                {{#each games}}
                <tr
                    data-id="{{this._id}}"
                    data-opponent="{{this.opponent}}"
                    data-venue="{{this.venue}}"
                    data-date="{{this.gameDate}}"
                    data-teamscore="{{this.teamScore}}"
                    data-opponentscore="{{this.opponentScore}}"
                    data-status="{{this.status}}"
                    data-result="{{this.result}}"
                    data-tournament="{{this.tournament._id}}"
                >
                    <td>{{@index}}</td>
                    <td>{{formatDate this.gameDate}}</td>
                    <td><strong>{{this.opponent}}</strong></td>
                    <td>
                        {{#if this.tournament}}
                            {{this.tournament.name}}<br>
                            <small class="text-muted">{{this.tournament.league}} · S{{this.tournament.season}}</small>
                        {{else}}
                            <span class="text-muted">—</span>
                        {{/if}}
                    </td>
                    <td>{{this.venue}}</td>
                    <td>
                        {{#if (eq this.status "Scheduled")}}
                            <span class="text-muted">TBD</span>
                        {{else}}
                            <strong>{{this.teamScore}}</strong> – {{this.opponentScore}}
                        {{/if}}
                    </td>
                    <td>
                        {{#if this.result}}
                            <span class="result {{this.result}}">{{this.result}}</span>
                        {{else}}
                            <span class="text-muted">—</span>
                        {{/if}}
                    </td>
                    <td>
                        <span class="status-badge status-{{this.status}}">{{this.status}}</span>
                    </td>
                    {{#if ../isAdminOrCoach}}
                    <td>
                        <button class="view-btn" onclick="openViewModal('{{this._id}}')">
                            <i class="fas fa-eye"></i> View
                        </button>
                        <button class="edit-btn" onclick="openEditModal(this)">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                        <button class="delete-btn" onclick="openDeleteModal('{{this._id}}', '{{this.opponent}}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                    {{/if}}
                </tr>
                {{else}}
                <tr><td colspan="9" class="text-center text-muted py-4">No games found.</td></tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    <div id="noResults" style="display:none;" class="text-center text-muted mt-4">
        <i class="fas fa-search fa-2x mb-2"></i>
        <p>No games match your search or filter.</p>
    </div>
</div>

<!-- ===== ADD GAME MODAL ===== -->
<div class="modal" id="addModal">
    <div class="modal-content">
        <span class="close" id="closeAddModal">&times;</span>
        <h3 id="modalTitle">Add Game</h3>
        <div id="addErrorMsg" class="alert-msg mb-3" style="display:none;"></div>
        <form id="addGameForm" onsubmit="return false;">
            <div class="form-row">
                <div class="form-group">
                    <select id="addTournament" required>
                        <option value="" disabled selected></option>
                        {{#each tournaments}}
                        <option value="{{this._id}}">{{this.name}} ({{this.league}} · S{{this.season}})</option>
                        {{/each}}
                    </select>
                    <label>Select Tournament</label>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <input type="text" id="addOpponent" placeholder=" " required>
                    <label>Opponent Team</label>
                </div>
                <div class="form-group">
                    <input type="text" id="addVenue" placeholder=" " required>
                    <label>Venue</label>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <input type="date" id="addDate" placeholder=" " required>
                    <label>Game Date</label>
                </div>
                <div class="form-group">
                    <input type="time" id="addStartTime" placeholder=" " required>
                    <label>Start Time</label>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <select id="addStatus" required>
                        <option value="NOT_STARTED">Not Started</option>
                        <option value="PLAYING">Playing</option>
                        <option value="PAUSED">Paused</option>
                        <option value="ENDED">Ended</option>
                    </select>
                    <label>Status</label>
                </div>
                <div class="form-group">
                    <input type="number" id="addCurrentPeriod" placeholder=" " min="1" max="8" value="1">
                    <label>Current Period</label>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <input type="text" id="addGameClock" placeholder=" " value="10:00" pattern="[0-9]{1,2}:[0-9]{2}">
                    <label>Game Clock (mm:ss)</label>
                </div>
            </div>
            
            <div class="form-row" id="addScoreRow">
                <div class="form-group">
                    <input type="number" id="addTeamScore" placeholder=" " min="0" value="0">
                    <label>Team Score</label>
                </div>
                <div class="form-group">
                    <input type="number" id="addOppScore" placeholder=" " min="0" value="0">
                    <label>Opponent Score</label>
                </div>
            </div>
            
            <h4 style="margin-top: 1rem; margin-bottom: 0.5rem; font-size: 0.95rem;">Quarter Scores</h4>
            <div class="form-row">
                <div class="form-group">
                    <input type="number" id="addQ1Team" placeholder=" " min="0" value="0">
                    <label>Q1 Team</label>
                </div>
                <div class="form-group">
                    <input type="number" id="addQ1Opp" placeholder=" " min="0" value="0">
                    <label>Q1 Opponent</label>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <input type="number" id="addQ2Team" placeholder=" " min="0" value="0">
                    <label>Q2 Team</label>
                </div>
                <div class="form-group">
                    <input type="number" id="addQ2Opp" placeholder=" " min="0" value="0">
                    <label>Q2 Opponent</label>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <input type="number" id="addQ3Team" placeholder=" " min="0" value="0">
                    <label>Q3 Team</label>
                </div>
                <div class="form-group">
                    <input type="number" id="addQ3Opp" placeholder=" " min="0" value="0">
                    <label>Q3 Opponent</label>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <input type="number" id="addQ4Team" placeholder=" " min="0" value="0">
                    <label>Q4 Team</label>
                </div>
                <div class="form-group">
                    <input type="number" id="addQ4Opp" placeholder=" " min="0" value="0">
                    <label>Q4 Opponent</label>
                </div>
            </div>
            
            <button type="button" id="saveGameBtn" onclick="addGame()">
                <i class="fas fa-save me-1"></i> Save Game
            </button>
        </form>
    </div>
</div>

