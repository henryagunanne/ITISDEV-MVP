                </div>
                <div class="form-group">
                    <input type="number" id="editQ4Opp" placeholder=" " min="0" value="0">
                    <label>Q4 Opponent</label>
                </div>
            </div>

            <button type="button" id="updateGameBtn" onclick="updateGame()">
                <i class="fas fa-save me-1"></i> Update Game
            </button>
        </form>
    </div>
</div>

<!-- ===== DELETE CONFIRM MODAL ===== -->
<div class="modal" id="deleteModal">
    <div class="modal-content" style="width:360px;">
        <span class="close" id="closeDeleteModal">&times;</span>
        <h3 style="font-size:18px;">Delete Game</h3>
        <p id="deleteConfirmText" class="text-center my-3"></p>
        <input type="hidden" id="deleteGameId">
        <div class="d-flex gap-2 justify-content-center">
            <button class="cancel-btn" id="cancelDeleteBtn">Cancel</button>
            <button class="delete-confirm-btn" onclick="confirmDelete()">
                <i class="fas fa-trash me-1"></i> Delete
            </button>
        </div>
    </div>
</div>

<!-- ===== VIEW GAME MODAL ===== -->
<div class="modal" id="viewModal">
    <div class="modal-content">
        <span class="close" id="closeViewModal">&times;</span>
        <h3>Game Details</h3>
        <div id="viewGameDetails" style="margin-top:1rem;">
            <!-- Game stats/details will be populated here by JS -->
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast-msg" style="display:none;"></div>

<script src="/src/javascript/admin-games.js"></script>
