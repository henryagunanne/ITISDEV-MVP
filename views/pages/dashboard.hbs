<!-- Main Content -->
<main class="col-md-10 ms-auto px-4 py-4">
    <div class="section-header">
        <h4 class="fw-bold text-success "><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h4>
        <div>
            <select id="seasonFilter" class="form-select" style="width:auto;">
                <option value="">All Seasons</option>
                {{#each tournaments}}
                <option value="{{this.name}}">{{this.name}}</option>
                {{/each}}
            </select>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Games Played</div>
                        <div class="stat-value" id="totalGames">0</div>
                    </div>
                    <i class="fas fa-basketball-ball stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Avg Points</div>
                    <div class="stat-value" id="avgPoints">0</div>
                </div>
                <i class="fas fa-bullseye stat-icon"></i>
            </div>
        </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Avg Rebounds</div>
                        <div class="stat-value" id="avgRebounds">0</div>
                    </div>
                    <i class="fas fa-arrows-alt stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">AVG Assists</div>
                        <div class="stat-value" id="avgAssists">0</div>
                    </div>
                    <i class="fas fa-hands-helping stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-8">
            <div class="chart-container">
                <h5><i class="fas fa-chart-line me-2"></i>Team Scoring by Game</h5>
                <canvas id="scoringChart" height="250"></canvas>
            </div>
        </div>
        <div class="col-md-4">
            <div class="chart-container">
                <h5><i class="fas fa-chart-pie me-2"></i>Win/Loss Record</h5>
                <canvas id="recordChart" height="250"></canvas>
            </div>
        </div>
    </div>

    <!-- Leaders -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="chart-container">
                <h5><i class="fas fa-star me-2"></i>Top Scorers (PPG)</h5>
                <div id="topScorers"></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="chart-container">
                <h5><i class="fas fa-hand-rock me-2"></i>Top Rebounders (RPG)</h5>
                <div id="topRebounders"></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="chart-container">
                <h5><i class="fas fa-hands-helping me-2"></i>Top Assists (APG)</h5>
                <div id="topAssists"></div>
            </div>
        </div>
    </div>

    <!-- Additional Stats Row -->
    <div class="row g-4 mt-2 mb-4 text-center">
        <div class="col-md-3">
            <div class="chart-container py-3">
                <h6 class="text-muted fw-semibold mb-2" style="font-size: 0.85rem;">Field Goal %(FG%)</h6>
                <h4 class="fw-bold mb-0" id="fgPercentage">0%</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="chart-container py-3">
                <h6 class="text-muted fw-semibold mb-2" style="font-size: 0.85rem;">3PT %</h6>
                <h4 class="fw-bold mb-0" id="threePtPercentage">0%</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="chart-container py-3">
                <h6 class="text-muted fw-semibold mb-2" style="font-size: 0.85rem;">FT%</h6>
                <h4 class="fw-bold mb-0" id="ftPercentage">0%</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="chart-container py-3">
                <h6 class="text-muted fw-semibold mb-2" style="font-size: 0.85rem;">Turnovers per Game</h6>
                <h4 class="fw-bold mb-0" id="avgTurnovers">0</h4>
            </div>
        </div>
    </div>
</main>
