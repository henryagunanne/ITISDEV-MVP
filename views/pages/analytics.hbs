<link rel="stylesheet" href="/src/css/analytics.css">

<main class="col-md-10 ms-auto px-4 py-4">

    <div class="main-content p-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Reports & Analytics</h2>
            <div>
                <button class="btn btn-outline-success me-2" onclick="exportCSV()">Export CSV</button>
                 <button class="btn btn-outline-success me-2" onclick="exportPDF()">Export PDF</button>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-3">
                <select id="seasonFilter" class="form-select">
                    <option value="">All Seasons</option>
                    {{#each tournaments}}
                    <option value="{{this.name}}">{{this.name}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="col-md-3">
                <input type="text" id="opponentFilter" class="form-control" placeholder="Opponent">
            </div>

            <div class="col-md-3">
                <input type="text" id="startDate" class="form-control" placeholder="Start Date">
            </div>

            <div class="col-md-3">
                <input type="text" id="endDate" class="form-control" placeholder="End Date">
            </div>
        </div>

        <!-- Overview Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm p-3">
                    <small>Total Games</small>
                    <h3 id="totalGames">0</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm p-3">
                    <small>Win Rate</small>
                    <h3 id="winRate">0%</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm p-3">
                    <small>Avg Points</small>
                    <h3 id="avgPoints">0</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm p-3">
                    <small>Team Efficiency</small>
                    <h3 id="teamEfficiency">0</h3>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="row g-3 mb-4">
            <div class="col-md-8">
                <div class="card p-3">
                    <h5>Points Trend</h5>
                    <canvas id="pointsChart"></canvas>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3">
                    <h5>Win / Loss</h5>
                    <canvas id="winLossChart"></canvas>
                </div>
            </div>
        </div>
        <br><br>
        <!-- Player Table -->
        <div class="row mb-3 d-flex justify-content-end">
            <div class="col-md-3">
                <select id="sortBy" class="form-select float-end">
                    <option value="ppg">Sort by PPG</option>
                    <option value="rpg">Sort by RPG</option>
                    <option value="apg">Sort by APG</option>
                    <option value="mpg">Sort by MPG</option>
                    <option value="efficiency">Sort by EFF</option>
                    <option value="tsPercentage">Sort by TS%</option>
                </select>
            </div>
        </div>
        <div class="card p-3">
            <h5>Player Performance</h5>
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Player</th>
                        <th>PPG</th>
                        <th>RPG</th>
                        <th>APG</th>
                        <th>MPG</th>
                        <th>EFF</th>
                        <th>TS%</th>
                        <th>Usage</th>
                    </tr>
                </thead>
                <tbody id="playerTable"></tbody>
            </table>
        </div>

        <div class="card mt-4">
            <div class="card-header"><h5>AI Insights</h5></div>
            <div class="card-body" id="aiInsights">
                Loading insights...
            </div>
        </div>
    </div>
</main>

<script src="/socket.io/socket.io.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="/src/javascript/analytics.js"></script>