<link rel="stylesheet" href="/src/css/user-profile.css">

<main class="col-md-10 ms-auto px-4 py-4">
  <div class="container mt-4 profile-container">

    <div class="row g-4">

        <!-- LEFT: USER SUMMARY -->
        <div class="col-lg-4">
            <div class="profile-sidebar text-center">

                <div class="profile-avatar">
                    <i class="fas fa-user"></i>
                </div>

                <h5 class="mt-3 mb-0">
                    {{user.firstName}} {{user.lastName}}
                </h5>

                <p class="text-muted mb-1">@{{user.username}}</p>

                <span class="badge bg-success">{{user.role}}</span>

                <hr>

                <div class="profile-meta">
                    <p><strong>Email:</strong><br>{{user.email}}</p>
                    <p><strong>Status:</strong>
                        {{#if user.isActive}}
                            <span class="text-success">Active</span>
                        {{else}}
                            <span class="text-danger">Inactive</span>
                        {{/if}}
                    </p>
                </div>
            </div>
        </div>

        <!-- RIGHT: TABS -->
        <div class="col-lg-8">
            <div class="profile-main">

                <!-- Tabs -->
                <ul class="nav nav-tabs mb-3" id="profileTabs">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#profileTab">
                            Profile Info
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#securityTab">
                            Security
                        </button>
                    </li>
                </ul>

                <div class="tab-content">

                    <!-- PROFILE INFO -->
                    <div class="tab-pane fade show active" id="profileTab">
                        <div class="profile-card">

                            <h5>Update Profile</h5>

                            <form id="updateProfileForm" class="needs-validation" novalidate>

                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <label>First Name</label>
                                        <input type="text" name="firstName" class="form-control"
                                            value="{{user.firstName}}" pattern="^[A-Za-zÀ-ÿ' ]{2,}$" required>
                                        <div class="invalid-feedback">Required</div>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Last Name</label>
                                        <input type="text" name="lastName" class="form-control"
                                            value="{{user.lastName}}" pattern="^[A-Za-zÀ-ÿ' ]{2,}$" required>
                                        <div class="invalid-feedback">Required</div>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Username</label>
                                        <input type="text" name="username" class="form-control"
                                            value="{{user.username}}" minlength="2" required>
                                        <div class="invalid-feedback">Required</div>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Email</label>
                                        <input type="email" name="email" class="form-control"
                                            value="{{user.email}}" pattern="^[^\s@]+@[^\s@]+\.[^\s@]+$" required>
                                        <div class="invalid-feedback">Enter valid email</div>
                                    </div>
                                </div>

                                <button class="btn btn-success mt-3">
                                    Save Changes
                                </button>

                            </form>
                        </div>
                    </div>

                    <!-- SECURITY -->
                    <div class="tab-pane fade" id="securityTab">
                        <div class="profile-card">

                            <h5>Change Password</h5>

                            <form id="changePasswordForm" class="needs-validation" novalidate>

                                <div class="mb-2">
                                    <label>Current Password</label>
                                    <input type="password" id="currentPassword" class="form-control" required>
                                    <div class="invalid-feedback">Required</div>
                                </div>

                                <div class="mb-2">
                                    <label>New Password</label>
                                    <input type="password" id="newPassword" class="form-control" minlength="8" required>
                                    <div class="invalid-feedback">Minimum 6 characters</div>
                                </div>

                                <div class="mb-2">
                                    <label>Confirm Password</label>
                                    <input type="password" id="confirmNewPassword" class="form-control" required>
                                    <div class="invalid-feedback">Passwords must match</div>
                                </div>

                                <button class="btn btn-warning mt-2">
                                    Update Password
                                </button>

                            </form>

                        </div>
                    </div>

                </div>

            </div>
        </div>

    </div>
</div>
</main>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="/src/javascript/user-profile.js"></script>
 <!-- Edit User Modal -->

<div class="modal fade" id="editUserModal">
    <div class="modal-dialog">
        <form id="editUserForm" class="needs-validation" novalidate>
            <div class="modal-body">

                <input type="hidden" id="userId">

                <input id="firstName" name="firstName" class="form-control mb-2" required>
                <div class="invalid-feedback">First name is required.</div>

                <input id="lastName" name="lastName" class="form-control mb-2" required>
                <div class="invalid-feedback">Last name is required.</div>

                <input id="username" name="username" class="form-control mb-2" required>
                <div class="invalid-feedback">Username is required.</div>

                <input id="email" name="email" type="email" class="form-control mb-2" required>
                <div class="invalid-feedback">Enter a valid email.</div>

                <select id="role" name="role" class="form-control mb-2" required>
                    <option value="">Select Role</option>
                    <option>Admin</option>
                    <option>Coach</option>
                    <option>Statistician</option>
                </select>
                <div class="invalid-feedback">Select a role.</div>

                <label>
                    <input type="checkbox" id="isActive" name="isActive"> Active
                </label>

            </div>
        </form>
    </div>
</div>