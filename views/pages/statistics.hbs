<link rel="stylesheet" href="/src/css/statistics.css">

<main class="col-md-10 ms-auto px-4 py-4">
    <div class="container-fluid py-3">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">

            <!-- LEFT: Title -->
            <h4 class="fw-bold text-success mb-0">Statistics</h4>

            <!-- RIGHT: Controls -->
            <div class="d-flex align-items-center gap-2 flex-wrap">

                <!-- Game Selector -->
                <select id="game-select" class="form-select form-select-sm w-auto">
                    <option value="">Select Game</option>
                </select>

                <!-- Manual Input Button -->
                <button id="manual-input-btn" class="btn btn-outline-secondary btn-sm">
                    <i class="bi-pencil"></i> Manual Input
                </button>

                <!-- Live Game Button -->
                <button id="live-input-btn" class="btn btn-success btn-sm">
                    <i class="bi-camera-video"></i> Live Game
                </button>

            </div>
        </div>

        <!-- TEAM SUMMARY -->
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="text-success fw-bold">LA SALLE</h6>
                        <div class="row text-center">
                            <div class="col"><h5 id="home-pts">0</h5><small>PTS</small></div>
                            <div class="col"><h5 id="home-fg">0%</h5><small>FG%</small></div>
                            <div class="col"><h5 id="home-reb">0</h5><small>REB</small></div>
                            <div class="col"><h5 id="home-ast">0</h5><small>AST</small></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="text-danger fw-bold" id="the-opps">OPPONENT</h6>
                        <div class="row text-center">
                            <div class="col"><h5 id="opp-pts">0</h5><small>PTS</small></div>
                            <div class="col"><h5 id="opp-fg">0%</h5><small>FG%</small></div>
                            <div class="col"><h5 id="opp-reb">0</h5><small>REB</small></div>
                            <div class="col"><h5 id="opp-ast">0</h5><small>AST</small></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PLAYER STATS TABLE -->
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Player Statistics</h6>

                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>PTS</th>
                                <th>FG</th>
                                <th>3PT</th>
                                <th>FT</th>
                                <th>REB</th>
                                <th>AST</th>
                                <th>STL</th>
                                <th>BLK</th>
                                <th>TO</th>
                                <th>PF</th>
                            </tr>
                        </thead>
                        <tbody id="stats-table-body">
                            <tr>
                                <td colspan="12" class="text-center text-muted">
                                    Select a game to view stats
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

        <div class="row mt-4">

            <!-- Team Comparison -->
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold">Team Comparison</h6>
                        <canvas id="teamChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Shooting Efficiency -->
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold">Shooting Efficiency</h6>
                        <canvas id="shootingChart"></canvas>
                    </div>
                </div>
            </div>

        </div>

        <!-- Game Insights -->
        <div class="card mt-4 shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold">Game Insights</h6>
                <div id="insights-box" class="small text-muted">
                    No insights yet
                </div>
            </div>
        </div>

    </div>
</main>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="/src/javascript/statistics.js"></script>