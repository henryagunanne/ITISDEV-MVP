<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{title}}</title>
        <!-- Favicon -->
        <link rel="icon" type="image/png" href="/assets/images/favicon/favicon-96x96.png" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
        <link rel="shortcut icon" href="/assets/images/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png" />
        <link rel="manifest" href="/assets/images/favicon/site.webmanifest" />


         <!-- CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet"> <!-- Bootsrap icons -->
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet"> <!-- Font Awesome icons -->
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="/src/css/stats.css">
        <link rel="stylesheet" href="/src/css/style.css">
    </head>

    <body>
        {{> navbar}}


        <div class="container-fluid">

            <div class="row">
                    {{> sidebar}}

                    {{{body}}}

            </div>

        </div>

        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
        <script src="/src/javascript/auth.js"></script>
        <script src="/src/javascript/stats.js"></script>

        <script>
            let scoringChart, recordChart;

            $(function () {
                // Only run dashboard logic if we're on the dashboard page
                if ($('#totalGames').length) {
                    loadDashboard();
                    $('#seasonFilter').on('change', loadDashboard);
                }
            });

            function loadDashboard() {
                const season = $('#seasonFilter').val();
                const qs = season ? `?season=${encodeURIComponent(season)}` : '';

                fetch('/api/analytics/dashboard' + qs)
                    .then(r => r.json())
                    .then(data => {
                        if (!data.success) throw new Error('API error');

                        const noData = data.gamesPlayed === 0;

                        $('#totalGames').text(data.gamesPlayed || 0);
                        $('#avgPoints').text(noData ? '—' : (data.avgPoints || 0).toFixed(1));
                        $('#avgRebounds').text(noData ? '—' : (data.avgRebounds || 0).toFixed(1));
                        $('#avgAssists').text(noData ? '—' : (data.avgAssists || 0).toFixed(1));

                        $('#fgPercentage').text(noData ? '—' : (data.fgPercentage || 0).toFixed(1) + '%');
                        $('#threePtPercentage').text(noData ? '—' : (data.threePtPercentage || 0).toFixed(1) + '%');
                        $('#ftPercentage').text(noData ? '—' : (data.ftPercentage || 0).toFixed(1) + '%');
                        $('#avgTurnovers').text(noData ? '—' : (data.avgTurnovers || 0).toFixed(1));

                        renderScoringChart(data.perGameScoring || []);
                        renderRecordChart(data.record || { wins: 0, losses: 0 });
                        renderLeaders('topScorers', data.leaders?.topScorers || [], 'ppg');
                        renderLeaders('topRebounders', data.leaders?.topRebounders || [], 'rpg');
                        renderLeaders('topAssists', data.leaders?.topAssists || [], 'apg');
                    })
                    .catch(err => {
                        console.error("Failed to load dashboard data:", err);
                        ['totalGames','avgPoints','avgRebounds','avgAssists','fgPercentage','threePtPercentage','ftPercentage','avgTurnovers']
                            .forEach(id => $('#' + id).text('—'));
                        ['topScorers','topRebounders','topAssists'].forEach(id =>
                            $('#' + id).html('<p class="text-muted small">No data available</p>')
                        );
                    });
            }

            function renderScoringChart(games) {
                if (scoringChart) scoringChart.destroy();
                const ctx = document.getElementById('scoringChart');
                if (!ctx) return;
                if (!games.length) {
                    $(ctx).closest('.chart-container').find('canvas').hide()
                        .after('<p class="text-muted text-center py-4">No game scoring data available.</p>');
                    return;
                }
                $(ctx).show().nextAll('p').remove();
                scoringChart = new Chart(ctx.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: games.map(g => g.opponent),
                        datasets: [
                            { label: 'Team Score', data: games.map(g => g.teamScore), backgroundColor: '#006F3C' },
                            { label: 'Opponent Score', data: games.map(g => g.opponentScore), backgroundColor: '#DEE2E6' }
                        ]
                    },
                    options: { responsive: true, scales: { y: { beginAtZero: true } } }
                });
            }

            function renderRecordChart(record) {
                if (recordChart) recordChart.destroy();
                const ctx = document.getElementById('recordChart');
                if (!ctx) return;
                if (!record.wins && !record.losses) {
                    $(ctx).hide().closest('.chart-container').find('p.no-data-msg').remove();
                    $(ctx).after('<p class="no-data-msg text-muted text-center py-4">No record data available.</p>');
                    return;
                }
                $(ctx).show().nextAll('p.no-data-msg').remove();
                recordChart = new Chart(ctx.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: [`Wins (${record.wins})`, `Losses (${record.losses})`],
                        datasets: [{ data: [record.wins, record.losses], backgroundColor: ['#006F3C', '#dc3545'] }]
                    },
                    options: { 
                        responsive: true, 
                        plugins: { 
                            legend: { 
                                position: 'bottom',
                                labels: {
                                    font: { size: 14, weight: 'bold' }
                                }
                            } 
                        } 
                    }
                });
            }

            function renderLeaders(containerId, leaders, statKey) {
                if (!leaders.length) {
                    $(`#${containerId}`).html('<p class="text-muted small text-center">No data available</p>');
                    return;
                }
                const html = leaders.map((l, i) => `
                    <div class="leader-card">
                        <div class="rank">${i + 1}</div>
                        <div class="player-info">
                            <div class="player-name">${l.player.firstName} ${l.player.lastName}</div>
                        </div>
                        <div class="player-stat">${l[statKey]}</div>
                    </div>
                `).join('');
                $(`#${containerId}`).html(html);
            }
        </script>
    </body>
</html>
