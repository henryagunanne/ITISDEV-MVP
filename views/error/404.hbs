<div class="container text-center mt-5">
    <h1 class="display-3 text-danger">{{code}}</h1>

    <h3>{{message}}</h3>
    <p class="text-muted">{{description}}</p>

    <p class="text-secondary">
        <small>URL: {{url}}</small>
    </p>

    <button class="btn btn-success mt-3" onClick="history.back()">
        <i class="bi-arrow-left"></i> Go Back
    </button>
</div>